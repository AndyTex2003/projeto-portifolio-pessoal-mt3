generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  phone          String?
  currentLevel   String
  birthDate      DateTime?
  notes          String?
  isActive       Boolean  @default(true)
  enrollmentDate DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("students")
}

